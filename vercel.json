{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/v1/internal/queue/drain",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/v1/internal/cron/watch-maintenance",
      "schedule": "0 6 * * *"
    }
  ]
}
