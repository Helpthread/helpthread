{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!node_modules",
      "!dist",
      "!coverage",
      "!fixtures/mail/observed",
      "!web/next-env.d.ts",
      "!web/tsconfig.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "overrides": [
    {
      "includes": ["web/src/components/ds/**"],
      "linter": {
        "rules": {
          "correctness": { "noUnusedImports": "off" },
          "complexity": { "useOptionalChain": "off" },
          "style": { "useTemplate": "off" },
          "suspicious": { "noExplicitAny": "off" },
          "a11y": {
            "noSvgWithoutTitle": "off",
            "useKeyWithClickEvents": "off",
            "noStaticElementInteractions": "off"
          }
        }
      }
    }
  ],
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
